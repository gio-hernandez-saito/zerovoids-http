{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"jsx": "react-jsx",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"types": ["vite/client"]
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
