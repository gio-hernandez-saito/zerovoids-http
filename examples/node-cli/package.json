{
	"name": "example-node-cli",
	"version": "0.0.0",
	"private": true,
	"description": "Pure Node CLI that fetches a public API through @zerovoids/http + ky transport",
	"type": "module",
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"start": "node dist/index.js",
		"dev": "tsc -p tsconfig.json --watch",
		"type-check": "tsc --noEmit"
	},
	"dependencies": {
		"@zerovoids/http": "workspace:*",
		"@zerovoids/http-transport-ky": "workspace:*",
		"ky": "catalog:"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"typescript": "catalog:"
	}
}
