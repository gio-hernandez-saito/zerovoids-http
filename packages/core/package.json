{
	"name": "@zerovoids/http",
	"version": "0.1.0",
	"description": "Vendor-normalizing multi-adapter HTTP client — core (zero peer dep)",
	"author": "zerovoids",
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": ["dist", "README.md", "LICENSE"],
	"sideEffects": false,
	"scripts": {
		"build": "vite build",
		"dev": "vite build --watch",
		"type-check": "tsc --noEmit",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"size": "size-limit",
		"clean": "rm -rf dist coverage .turbo"
	},
	"keywords": [
		"http",
		"fetch",
		"api-client",
		"vendor-adapter",
		"typescript",
		"standard-schema",
		"zero-dep",
		"tree-shakable",
		"esm",
		"cjs"
	],
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"devDependencies": {
		"@size-limit/preset-small-lib": "catalog:",
		"@vitest/coverage-v8": "catalog:",
		"expect-type": "catalog:",
		"size-limit": "catalog:",
		"typescript": "catalog:",
		"vite": "catalog:",
		"vite-plugin-dts": "catalog:",
		"vitest": "catalog:"
	},
	"size-limit": [
		{
			"name": "core (ESM, min+gz)",
			"path": "dist/index.js",
			"limit": "5 KB"
		}
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/gio-hernandez-saito/zerovoids-http.git",
		"directory": "packages/core"
	},
	"homepage": "https://github.com/gio-hernandez-saito/zerovoids-http/tree/main/packages/core#readme",
	"bugs": "https://github.com/gio-hernandez-saito/zerovoids-http/issues"
}
